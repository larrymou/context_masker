#!/bin/bash
# context-masker - Shell wrapper for coding agents
# Intercepts tool output and masks sensitive data before LLM calls

set -e

MASKER_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MASKER_BIN="$MASKER_DIR/../dist/cli.js"

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

usage() {
    echo "Usage: context-masker [command] [args...]"
    echo ""
    echo "Commands:"
    echo "  mask <text>     Mask sensitive data in text"
    echo "  restore <text>  Restore masked placeholders"
    echo "  wrap <command>  Wrap a command to auto-mask output"
    echo "  setup <tool>    Print integration instructions for a tool"
    echo ""
    echo "Examples:"
    echo "  context-masker mask 'Email: user@example.com'"
    echo "  context-masker wrap git status"
    echo "  context-masker setup claude-code"
}

mask_text() {
    node "$MASKER_BIN" mask "$1"
}

restore_text() {
    node "$MASKER_BIN" restore "$1"
}

wrap_command() {
    local output
    output=$("$@" 2>&1)
    local rc=$?

    echo "$(mask_text "$output")"
    exit $rc
}

setup_tool() {
    local tool="$1"
    case "$tool" in
        claude-code|claude)
            echo "Claude Code integration:"
            echo "  Add to ~/.bashrc or ~/.zshrc:"
            echo "    alias claude='context-masker wrap claude'"
            ;;
        opencode)
            echo "OpenCode integration:"
            echo '  Add to opencode config: "middleware": ["context-masker"]'
            ;;
        cursor|windsurf)
            echo "Cursor/Windsurf integration:"
            echo "  Add to .cursorrules:"
            echo "    When handling tool outputs containing sensitive data, use context-masker to mask them"
            ;;
        hermes)
            echo "Hermes integration:"
            echo "  Add to agent.config.yml:"
            echo '    tools: [{name: shell, preUse: "context-masker mask", postUse: "context-masker restore"}]'
            ;;
        *)
            echo -e "${RED}Unknown tool: $tool${NC}" >&2
            echo "Supported: claude-code, opencode, cursor, hermes, windsurf" >&2
            exit 1
            ;;
    esac
}

case "${1:-}" in
    mask)
        shift
        mask_text "$*"
        ;;
    restore)
        shift
        restore_text "$*"
        ;;
    wrap)
        shift
        wrap_command "$@"
        ;;
    setup)
        shift
        setup_tool "${1:-}"
        ;;
    --help|-h|help)
        usage
        ;;
    *)
        if [ $# -eq 0 ]; then
            usage
        else
            wrap_command "$@"
        fi
        ;;
esac
