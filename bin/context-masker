#!/bin/bash
# context-masker - Shell wrapper for coding agents
# Intercepts tool output and masks sensitive data before LLM calls

set -e

MASKER_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MASKER_BIN="$MASKER_DIR/../dist/cli.js"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

usage() {
    echo "Usage: context-masker [command] [args...]"
    echo ""
    echo "Commands:"
    echo "  mask <text>     Mask sensitive data in text"
    echo "  restore <text>  Restore masked placeholders"
    echo "  wrap <command>  Wrap a command to auto-mask output"
    echo "  init <tool>     Initialize for specific tool"
    echo ""
    echo "Examples:"
    echo "  context-masker mask 'Email: user@example.com'"
    echo "  context-masker wrap git status"
    echo "  context-masker init claude-code"
}

mask_text() {
    local text="$1"
    node "$MASKER_BIN" mask "$text"
}

restore_text() {
    local text="$1"
    node "$MASKER_BIN" restore "$text"
}

wrap_command() {
    local cmd="$*"
    local output
    output=$($cmd 2>&1) || true
    
    local masked
    masked=$(mask_text "$output")
    
    echo "$masked"
}

init_tool() {
    local tool="$1"
    
    case "$tool" in
        claude-code|claude)
            echo -e "${GREEN}Initializing for Claude Code...${NC}"
            cat > ~/.claude/settings.json << 'EOF'
{
  "env": {
    "CONTEXT_MASKER_ENABLED": "1"
  }
}
EOF
            echo -e "${GREEN}Done! Restart Claude Code to apply.${NC}"
            ;;
        opencode)
            echo -e "${GREEN}Initializing for OpenCode...${NC}"
            echo "Add to your opencode config:"
            echo '  "middleware": ["context-masker"]'
            ;;
        cursor)
            echo -e "${GREEN}Initializing for Cursor...${NC}"
            echo "Add to your .cursorrules:"
            echo '  Use context-masker to mask sensitive data'
            ;;
        hermes|windsurf)
            echo -e "${GREEN}Initializing for Hermes/Windsurf...${NC}"
            echo "Add to your agent config:"
            echo '  preToolUse: "context-masker mask"'
            echo '  postToolUse: "context-masker restore"'
            ;;
        *)
            echo -e "${RED}Unknown tool: $tool${NC}"
            echo "Supported tools: claude-code, opencode, cursor, hermes, windsurf"
            exit 1
            ;;
    esac
}

# Main
case "${1:-}" in
    mask)
        shift
        mask_text "$*"
        ;;
    restore)
        shift
        restore_text "$*"
        ;;
    wrap)
        shift
        wrap_command "$@"
        ;;
    init)
        shift
        init_tool "${1:-}"
        ;;
    --help|-h|help)
        usage
        ;;
    *)
        if [ $# -eq 0 ]; then
            usage
        else
            wrap_command "$@"
        fi
        ;;
esac
